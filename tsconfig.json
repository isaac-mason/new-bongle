{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "lib": ["ES2022", "DOM"],
        "moduleResolution": "bundler",
        "types": [],
        "strict": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "noEmit": true,
        "skipLibCheck": true,
        "rootDir": "./",
        "allowSyntheticDefaultImports": true
    },
    "include": ["./src"],
    "exclude": ["./dist", "./node_modules"]
}
