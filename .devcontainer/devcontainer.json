{
    "name": "new-bongle",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:24",
    // `bongle edit` renders icons in-process with WebGPU (Dawn via the
    // `webgpu` package). Headless codespaces have no GPU, so install mesa's
    // software Vulkan driver (lavapipe) for Dawn to render against on Linux.
    "onCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends mesa-vulkan-drivers && sudo rm -rf /var/lib/apt/lists/*",
    "postCreateCommand": "npm install",
    "postAttachCommand": "npm run edit",
    "forwardPorts": [3002],
    "portsAttributes": {
        "3002": { "label": "bongle editor", "onAutoForward": "openBrowser" }
    },
    "customizations": {
        "vscode": {
            "extensions": ["biomejs.biome"]
        }
    }
}
